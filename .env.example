# Beever Atlas v2 — Environment Variables
# Copy to .env and fill in values

# === Data Stores ===
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/beever_atlas_dev
MONGODB_URI=mongodb://localhost:27017/beever_atlas
REDIS_URL=redis://localhost:6379

# === LLM Providers ===
GOOGLE_API_KEY=                # Gemini models for ADK agents
ANTHROPIC_API_KEY=             # Claude fallback via LiteLLM

# === External Services ===
JINA_API_KEY=                  # Jina v4 embeddings
JINA_EMBEDDING_URL=https://api.jina.ai/v1/embeddings
TAVILY_API_KEY=                # External web search
ENABLE_EXTERNAL_SEARCH=true    # Enable/disable web search
TAVILY_SEARCH_DEPTH=basic      # basic or advanced
TAVILY_MAX_RESULTS=5           # Max web results to fetch

# === Bot Service (Chat SDK) ===
SLACK_BOT_TOKEN=                # Slack bot token (xoxb-...)
SLACK_SIGNING_SECRET=           # Slack app signing secret
BOT_PORT=3001                   # Bot HTTP server port
BACKEND_URL=http://localhost:8000  # Python backend URL (bot → backend)
BRIDGE_API_KEY=                 # Shared secret for bridge auth (optional in dev)

# === Adapter Mode ===
ADAPTER_MOCK=true               # Set to "true" to use mock fixture data (no Slack needed)

# === Application ===
BRIDGE_URL=http://localhost:3001   # Bot bridge URL (backend → bot)
BEEVER_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
